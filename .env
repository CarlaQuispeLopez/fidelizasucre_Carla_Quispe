# ================================================
# ClientesFieles - Variables de Entorno
# Copia este archivo como .env y edita los valores
# ================================================

# Configuracion MySQL (XAMPP local)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=clientesfieles
DB_PORT=3306

# JWT (cambia esto por una clave larga y secreta)
JWT_SECRET=clientesfieles_clave_secreta_2026_cambiame

# Entorno
NODE_ENV=development
PORT=3000

